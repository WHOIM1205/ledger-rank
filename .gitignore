# ============================================================
# LedgerRank — root .gitignore
# ============================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ---- Databases (runtime data — never commit) ----
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ---- Environment / secrets ----
.env
.env.*
!.env.example
# (frontend uses .env.local — covered by .env.* above)

# ---- Node / frontend ----
node_modules/
dist/
.vite/
*.local

# ---- Editor / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
