# ---- LedgerRank backend configuration (copy to .env) ----

# SQLite database location (relative to the backend/ working directory).
LEDGERRANK_DATABASE_URL=sqlite:///./data/ledgerrank.db

# How long (ms) a blocked SQLite writer waits for the lock before raising
# SQLITE_BUSY. Higher = more patient under concurrency.
LEDGERRANK_SQLITE_BUSY_TIMEOUT_MS=5000

# Echo SQL to stdout (useful while developing; keep false for demo).
LEDGERRANK_SQL_ECHO=false

# ---- Ranking weights (used in a later step; documented here for visibility) ----
LEDGERRANK_WEIGHT_AMOUNT=0.5
LEDGERRANK_WEIGHT_COUNT=0.3
LEDGERRANK_WEIGHT_RECENCY=0.2
LEDGERRANK_RECENCY_TAU_DAYS=7
